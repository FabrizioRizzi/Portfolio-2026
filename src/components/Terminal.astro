---
import { getWelcomeMessage } from "../utils/commands";

// Server-render both desktop and mobile welcome messages for better FCP
const desktopWelcomeMessage = getWelcomeMessage(900);
const mobileWelcomeMessage = getWelcomeMessage(350);
---

<header class="terminal-header" role="banner">
  <h1 class="visually-hidden">Fabrizio's Interactive Terminal Portfolio</h1>
  <div class="window-buttons" role="group" aria-label="Window controls">
    <button
      class="btn btn-close"
      aria-label="Close window (decorative)"
      tabindex="-1"
      disabled></button>
    <button
      class="btn btn-minimize"
      aria-label="Minimize window (decorative)"
      tabindex="-1"
      disabled></button>
    <button
      class="btn btn-maximize"
      aria-label="Maximize window (decorative)"
      tabindex="-1"
      disabled></button>
  </div>
  <div class="terminal-title" aria-label="Terminal session">
    guest@portfolio:~
  </div>
</header>
<div class="terminal-body" role="region" aria-label="Terminal interface">
  <!-- Screen reader instructions -->
  <div class="visually-hidden" id="terminal-instructions">
    Interactive terminal portfolio. Type commands and press Enter to execute.
    Use arrow up and down to navigate command history. Press Tab for command
    autocompletion. Type 'help' for available commands. Press question mark for
    keyboard shortcuts.
  </div>

  <!-- Status announcer for screen readers -->
  <div
    id="terminal-status"
    class="visually-hidden"
    role="status"
    aria-live="polite"
    aria-atomic="true"
  >
  </div>

  <!-- Terminal output with log role -->
  <div
    id="terminal-output"
    class="terminal-output"
    role="log"
    aria-live="polite"
    aria-relevant="additions"
    aria-label="Command output history"
  >
    <!-- Server-rendered welcome messages for instant FCP - show appropriate one based on screen size -->
    <pre
      class="output-line welcome-banner welcome-banner-desktop">{desktopWelcomeMessage}</pre>
    <pre
      class="output-line welcome-banner welcome-banner-mobile">{mobileWelcomeMessage}</pre>
  </div>

  <div class="terminal-input-line">
    <label for="terminal-input" class="prompt" id="terminal-prompt"
      >guest@portfolio:~$</label
    >
    <input
      type="text"
      id="terminal-input"
      class="terminal-input"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
      autofocus
      aria-label="Terminal command input"
      aria-describedby="terminal-instructions"
      aria-invalid="false"
    />
    <span class="cursor" aria-hidden="true"></span>
  </div>
</div>

<style>
  .terminal-header {
    background: var(--terminal-chrome);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--terminal-border);
    position: relative;
  }

  .window-buttons {
    display: flex;
    gap: 8px;
    z-index: 2;
  }

  .btn {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
    border: none;
    padding: 0;
    cursor: not-allowed;
    opacity: 0.6;
  }

  .btn-close {
    background: #ff5f56;
  }

  .btn-minimize {
    background: #ffbd2e;
  }

  .btn-maximize {
    background: #27c93f;
  }

  /* Hide button outline since they're decorative */
  .btn:focus {
    outline: none;
  }

  .terminal-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    color: var(--terminal-text);
    font-size: 14px;
    opacity: 0.8;
  }

  .terminal-body {
    flex: 1;
    background: var(--terminal-bg);
    padding: 20px;
    overflow-y: auto;
    overflow-x: hidden; /* Prevent horizontal scroll */
    display: flex;
    flex-direction: column;
    color: var(--terminal-text);
    font-size: 14px;
    line-height: 1.5;
    /* Performance optimization */
    contain: layout style paint;
  }

  .terminal-output {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden; /* Prevent horizontal scroll */
    margin-bottom: 10px;
    /* Improve rendering performance for dynamic content */
    content-visibility: auto;
    width: 100%; /* Ensure it respects container width */
  }

  /* Global styles for dynamically created elements */
  :global(.output-line) {
    margin: 0;
    padding: 0;
    white-space: pre-wrap;
    word-wrap: break-word;
    font-family: inherit;
    color: inherit;
  }

  :global(.output-line.welcome-banner) {
    color: var(--terminal-highlight);
    line-height: 1.2;
    font-size: 14px;
    overflow-x: auto; /* Allow horizontal scroll within banner if needed */
    max-width: 100%;
  }

  /* Show/hide appropriate banner based on screen size */
  :global(.welcome-banner-mobile) {
    display: none;
  }

  :global(.welcome-banner-desktop) {
    display: block;
  }

  :global(.output-line.error) {
    color: var(--terminal-error);
  }

  :global(.command-line) {
    margin: 10px 0 5px 0;
  }

  :global(.command-prompt) {
    color: var(--terminal-prompt);
  }

  :global(.command-text) {
    color: var(--terminal-highlight);
    margin-left: 8px;
  }

  /* Link styles */
  :global(.output-line a) {
    color: var(--terminal-highlight);
    text-decoration: underline;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  :global(.output-line a:hover) {
    opacity: 0.8;
    text-decoration: underline;
  }

  :global(.output-line a:focus) {
    outline: 2px solid var(--terminal-highlight);
    outline-offset: 2px;
  }

  :global(.output-line a:visited) {
    color: var(--terminal-highlight);
  }

  .terminal-input-line {
    display: flex;
    align-items: center;
    margin-top: auto;
    position: relative;
  }

  .prompt {
    color: var(--terminal-prompt);
    margin-right: 8px;
    white-space: nowrap;
  }

  .terminal-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--terminal-text);
    font-family: inherit;
    font-size: inherit;
    caret-color: transparent;
  }

  /* Prevent iOS zoom on input focus - ensure 16px minimum */
  @media (max-width: 768px) {
    .terminal-input {
      font-size: 16px;
    }
  }

  /* Remove focus outline for terminal input - cursor provides focus indication */
  .terminal-input:focus {
    outline: none;
  }

  .terminal-input:focus-visible {
    outline: none;
  }

  .cursor {
    position: absolute;
    width: 8px;
    height: 18px;
    background: var(--terminal-text);
    animation: blink 1s infinite;
    pointer-events: none;
  }

  @keyframes blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }

  /* Disable cursor blinking for reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .cursor {
      animation: none;
      opacity: 1;
    }
  }

  /* Scrollbar styles */
  .terminal-body::-webkit-scrollbar,
  .terminal-output::-webkit-scrollbar {
    width: 8px;
  }

  .terminal-body::-webkit-scrollbar-track,
  .terminal-output::-webkit-scrollbar-track {
    background: var(--terminal-bg);
  }

  .terminal-body::-webkit-scrollbar-thumb,
  .terminal-output::-webkit-scrollbar-thumb {
    background: var(--terminal-border);
    border-radius: 4px;
  }

  .terminal-body::-webkit-scrollbar-thumb:hover,
  .terminal-output::-webkit-scrollbar-thumb:hover {
    background: #555;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .terminal-window {
      max-height: none;
      height: 100vh;
      height: 100dvh; /* Use dynamic viewport height for better mobile support */
      border-radius: 0;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
    }

    .terminal-body {
      padding: 15px;
      font-size: 12px;
    }

    :global(.output-line.welcome-banner) {
      font-size: 11px;
      line-height: 1.1;
    }

    /* Show mobile banner, hide desktop banner */
    :global(.welcome-banner-mobile) {
      display: block;
    }

    :global(.welcome-banner-desktop) {
      display: none;
    }

    .terminal-title {
      font-size: 12px;
    }

    .btn {
      width: 10px;
      height: 10px;
    }
  }

  @media (max-width: 480px) {
    .terminal-body {
      padding: 10px;
      font-size: 11px;
    }

    :global(.output-line.welcome-banner) {
      font-size: 10px;
      line-height: 1.1;
    }

    .terminal-header {
      padding: 10px 12px;
    }

    .prompt {
      font-size: 16px;
    }
  }

  /* Very small screens */
  @media (max-width: 360px) {
    .terminal-body {
      padding: 6px;
      font-size: 10px;
    }

    :global(.output-line.welcome-banner) {
      font-size: 8px; /* Smaller font to fit banner */
      line-height: 1;
      letter-spacing: -0.5px; /* Tighten spacing */
      overflow-x: auto; /* Allow scroll only within banner if still too wide */
      -webkit-overflow-scrolling: touch; /* Smooth scrolling on iOS */
    }

    :global(.output-line) {
      overflow-wrap: break-word;
      word-break: break-word;
    }
  }
</style>

<script>
  import {
    executeCommand,
    getCommandSuggestion,
    getWelcomeMessage,
    shortcuts,
  } from "../utils/commands";
  import { linkifyText } from "../utils/linkify";
  import { CommandHistory } from "../utils/commandHistory";
  import { ScreenReaderAnnouncer } from "../utils/accessibility";
  import {
    scrollToBottom,
    updateCursorPosition,
    getBreakpoint,
    debounce,
  } from "../utils/domHelpers";

  // Terminal state
  const commandHistory = new CommandHistory();
  let currentWidth = window.innerWidth;

  // DOM elements - defer initialization until DOMContentLoaded for faster FCP
  let input: HTMLInputElement;
  let output: HTMLDivElement;
  let cursor: HTMLElement;
  let terminalBody: HTMLElement;
  let prompt: HTMLElement;
  let announcer: ScreenReaderAnnouncer;

  function initializeDOMElements() {
    input = document.getElementById("terminal-input") as HTMLInputElement;
    output = document.getElementById("terminal-output") as HTMLDivElement;
    cursor = document.querySelector(".cursor") as HTMLElement;
    terminalBody = document.querySelector(".terminal-body") as HTMLElement;
    prompt = document.querySelector(".prompt") as HTMLElement;
    announcer = new ScreenReaderAnnouncer("terminal-status");
  }

  function displayWelcomeMessage() {
    const desktopMessage = getWelcomeMessage(900);
    const mobileMessage = getWelcomeMessage(350);

    // Linkify welcome messages (linkifyText handles escaping internally)
    const linkedDesktop = linkifyText(desktopMessage);
    const linkedMobile = linkifyText(mobileMessage);

    // Replace output with both banners (CSS will handle which one to show)
    output.innerHTML = `
      <pre class="output-line welcome-banner welcome-banner-desktop">${linkedDesktop}</pre>
      <pre class="output-line welcome-banner welcome-banner-mobile">${linkedMobile}</pre>
    `;
  }

  // Defer resize handler to reduce initial JS execution
  const handleResize = debounce(() => {
    const newWidth = window.innerWidth;
    const oldBreakpoint = getBreakpoint(currentWidth);
    const newBreakpoint = getBreakpoint(newWidth);

    if (oldBreakpoint !== newBreakpoint) {
      // Skip the first 2 elements (desktop and mobile banners)
      const outputLines = Array.from(output.children).slice(2);
      displayWelcomeMessage();
      updateCursorPosition(cursor, input, prompt);
      outputLines.forEach((line) => output.appendChild(line));
      currentWidth = newWidth;
    }
  }, 150);

  function addOutput(content: string, isError: boolean = false) {
    if (content === "__CLEAR__") {
      // Clear all output and show only welcome messages
      displayWelcomeMessage();
      announcer.announce("Terminal cleared");
      scrollToBottom(terminalBody, output);
      return;
    }

    const pre = document.createElement("pre");
    pre.className = `output-line${isError ? " error" : ""}`;
    
    // Linkify URLs (this function also handles escaping internally)
    const linkedContent = linkifyText(content);
    
    // Use innerHTML since we have links
    pre.innerHTML = linkedContent;
    output.appendChild(pre);

    // Announce to screen readers
    if (isError) {
      announcer.announce(`Error: ${content.split("\n")[0]}`, "assertive");
    }

    // Scroll to bottom
    scrollToBottom(terminalBody, output);
  }

  // Add command line to output
  function addCommandLine(command: string) {
    const div = document.createElement("div");
    div.className = "command-line";
    div.innerHTML = `<span class="command-prompt">guest@portfolio:~$</span><span class="command-text">${command}</span>`;
    output.appendChild(div);

    // Scroll to bottom after adding command
    scrollToBottom(terminalBody, output);
  }

  function handleCommand(command: string) {
    if (command.trim()) {
      // Handle special keyboard shortcuts help
      if (command.trim() === "?") {
        showKeyboardShortcuts();
        input.value = "";
        updateCursorPosition(cursor, input, prompt);
        return;
      }

      commandHistory.add(command);

      addCommandLine(command);

      const result = executeCommand(command, window.innerWidth);
      if (result.content) {
        addOutput(result.content, result.type === "error");
        // Update aria-invalid based on result
        input.setAttribute(
          "aria-invalid",
          result.type === "error" ? "true" : "false"
        );
      }

      // Announce command completion to screen readers
      if (result.type === "success" && command.trim() !== "clear") {
        announcer.announce(`Command ${command} executed successfully`);
      }
    }

    input.value = "";
    updateCursorPosition(cursor, input, prompt);

    scrollToBottom(terminalBody, output);
  }

  function showKeyboardShortcuts() {
    addCommandLine("?");
    addOutput(shortcuts, false);
    announcer.announce("Keyboard shortcuts displayed");
  }

  function handleTabCompletion() {
    const partial = input.value.trim();
    if (partial) {
      const suggestion = getCommandSuggestion(partial);
      if (suggestion) {
        input.value = suggestion;
        updateCursorPosition(cursor, input, prompt);
        announcer.announce(`Command autocompleted to ${suggestion}`);
      }
    }
  }

  function clearInput() {
    input.value = "";
    commandHistory.reset();
    updateCursorPosition(cursor, input, prompt);
    input.setAttribute("aria-invalid", "false");
    announcer.announce("Input cleared");
  }

  // Initialize everything when DOM is ready
  function initialize() {
    initializeDOMElements();
    updateCursorPosition(cursor, input, prompt);

    // Focus input
    input.focus();

    // Add event listeners
    window.addEventListener("resize", handleResize, { passive: true });

    terminalBody.addEventListener("click", () => {
      input.focus();
    });

    input.addEventListener("input", () => {
      updateCursorPosition(cursor, input, prompt);
    });

    input.addEventListener("keydown", handleKeyDown);
  }

  function handleKeyDown(e: KeyboardEvent) {
    if (e.key === "Enter") {
      e.preventDefault();
      handleCommand(input.value);
    } else if (e.key === "Tab") {
      e.preventDefault();
      handleTabCompletion();
    } else if (e.key === "Escape") {
      e.preventDefault();
      clearInput();
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      commandHistory.saveCurrentInput(input.value);
      const previousCommand = commandHistory.navigateUp();
      if (previousCommand !== null) {
        input.value = previousCommand;
        updateCursorPosition(cursor, input, prompt);
        announcer.announce(`History: ${previousCommand}`);
      } else if (commandHistory.isAtBeginning()) {
        announcer.announce("Beginning of command history");
      }
    } else if (e.key === "ArrowDown") {
      e.preventDefault();
      const nextCommand = commandHistory.navigateDown();
      input.value = nextCommand;
      updateCursorPosition(cursor, input, prompt);
      if (commandHistory.isAtEnd()) {
        announcer.announce("Returned to current input");
      } else {
        announcer.announce(`History: ${nextCommand}`);
      }
    } else if (e.key === "l" && e.ctrlKey) {
      e.preventDefault();
      handleCommand("clear");
    } else if (e.key === "?" && input.value === "") {
      e.preventDefault();
      input.value = "?";
      handleCommand("?");
    }
  }

  // Use DOMContentLoaded for faster initial render
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initialize);
  } else {
    initialize();
  }
</script>
